PORT=3000
NODE_ENV=production
CACHE_PATH=./cache.db
# Optional overrides for fallback extractors.
# NOTE (2026-04): public Piped mirrors are mostly dead; public Cobalt v7 API
# was shut down Nov 2024. Default COBALT_BASE_URL now points at a loopback
# address that expects a self-hosted Cobalt v11 container (see
# docker/docker-compose.cobalt.yml + docker/README.md).
PIPED_BASE_URL=https://pipedapi.kavin.rocks
COBALT_BASE_URL=http://127.0.0.1:9000
